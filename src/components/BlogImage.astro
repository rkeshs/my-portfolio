---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  width,
  height,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;
---

<figure
  class="is-loading"
  data-blog-image
  style={`--blog-image-width: ${width}px; --blog-image-ratio: ${width} / ${height};`}
>
  <span class="skeleton" aria-hidden="true"></span>
  <img
    {src}
    {alt}
    {width}
    {height}
    {loading}
    {fetchpriority}
    decoding="async"
  />
</figure>

<script>
  document.querySelectorAll<HTMLElement>("[data-blog-image]").forEach((container) => {
    if (container.dataset["enhanced"] !== undefined) return;

    container.dataset["enhanced"] = "";
    container.classList.add("is-loading");

    const image = container.querySelector("img");
    if (!image) return;

    const reveal = async () => {
      try {
        await image.decode();
      } catch {
        // A failed decode still needs to reveal the browser's fallback UI.
      }

      container.classList.remove("is-loading");
    };

    if (image.complete) {
      void reveal();
    } else {
      image.addEventListener("load", () => void reveal(), { once: true });
      image.addEventListener("error", () => container.classList.remove("is-loading"), {
        once: true,
      });
    }
  });
</script>

<style>
  figure {
    position: relative;
    width: min(100%, var(--blog-image-width));
    aspect-ratio: var(--blog-image-ratio);
    margin-inline: auto;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--mist);
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
    transition: opacity 250ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .skeleton {
    position: absolute;
    inset: 0;
    display: none;
    background: linear-gradient(
      100deg,
      var(--mist) 30%,
      color-mix(in oklch, var(--mist) 82%, var(--foreground)) 50%,
      var(--mist) 70%
    );
    background-size: 200% 100%;
  }

  .is-loading .skeleton {
    display: block;
    animation: shimmer 1.2s ease-in-out infinite;
  }

  .is-loading img {
    opacity: 0;
  }

  @keyframes shimmer {
    from {
      background-position: 200% 0;
    }

    to {
      background-position: -200% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    img {
      transition: none;
    }

    .is-loading .skeleton {
      animation: none;
    }
  }
</style>
