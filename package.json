{
  "name": "my-portfolio",
  "version": "0.0.1",
  "description": "Personal portfolio built with Astro, React, and Tailwind CSS",
  "license": "MIT",
  "author": "Rishikesh S",
  "repository": {
    "type": "git",
    "url": "https://github.com/rkeshs/my-portfolio"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:fix": "oxlint --fix --deny-warnings --report-unused-disable-directives",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "tsc --noEmit && astro check"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@tailwindcss/vite": "4.3.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "astro": "7.1.0",
    "framer-motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "mdast-util-to-hast": "13.2.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
